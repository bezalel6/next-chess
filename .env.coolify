# === Database Configuration ===

POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeThisSecurePassword123!
POSTGRES_DB=next_chess

# === Email Configuration (Optional) ===

# For production, replace with actual SMTP settings
EMAIL_ENABLED=true
EMAIL_AUTOCONFIRM=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_SENDER_NAME=Next Chess
SMTP_ADMIN_EMAIL=admin@yourdomain.com

# === Port Configuration (Usually managed by Coolify) ===

APP_PORT=3000
KONG_PORT=54321
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# === Application Settings ===

NODE_ENV=production
SKIP_ENV_VALIDATION=true
DISABLE_SIGNUP=false